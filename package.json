{
  "name": "kenyagov-info",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/cf-clean.mjs && opennextjs-cloudflare build && node scripts/check-worker-size.mjs",
    "build:next": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "generate:og": "node scripts/generate-og-image.mjs",
    "cf:build": "node scripts/cf-clean.mjs && opennextjs-cloudflare build && node scripts/check-worker-size.mjs",
    "preview": "pnpm run cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "deploy:only": "opennextjs-cloudflare deploy",
    "upload": "pnpm run cf:build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "postinstall": "node scripts/patch-opennext-windows.mjs",
    "studio:deploy": "npx --yes sanity@latest deploy",
    "studio:dev": "npx --yes sanity@latest dev"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@portabletext/react": "^6.2.0",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/postcss": "^4.2.4",
    "date-fns": "^4.2.1",
    "govuk-frontend": "^6.1.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.4",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.4",
    "typescript": "^5.0.0",
    "wrangler": "^4.110.0"
  }
}
